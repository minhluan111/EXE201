FROM (
    SELECT r.id, r.created_at, r.end_time, r.guest_count, r.guest_email, r.guest_name, r.guest_phone, r.reservation_code, r.reservation_date, r.seating_area_id, r.special_note, r.start_time, r.status, r.table_name
